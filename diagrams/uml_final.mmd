classDiagram
    class Owner {
        +str name
        +int available_time_minutes
        +dict preferences
        +get_owner_details() str
    }

    class Pet {
        +str name
        +str species
        +str breed
        +int age
        +Owner owner
        +get_profile() str
    }

    class Task {
        +str title
        +int duration_minutes
        +Priority priority
        +str category
        +TimeOfDay time_of_day
        +bool is_completed
        +str specific_time
        +str pet_name
        +str recurrence
        +date due_date
        +update_status(completed: bool) Optional[Task]
        +get_start_minutes() Optional[int]
        +get_end_minutes() Optional[int]
    }

    class Scheduler {
        +Pet pet
        +Owner owner
        +list tasks
        +list plan
        +str reasoning
        +add_task(task: Task) void
        +mark_task_complete(task: Task) Optional[Task]
        +detect_conflicts(tasks: list) list
        +filter_tasks(pet_filter: str, status_filter: str, tasks: list) list
        +sort_tasks_by_time(tasks: list) list
        +generate_plan(pet_filter: str, status_filter: str) list
        +get_reasoning() str
    }

    Pet "1" --> "1" Owner : belongs to
    Scheduler "1" --> "1" Pet : schedules for
    Scheduler "1" --> "1" Owner : checks constraints of
    Scheduler "1" *-- "*" Task : organizes
