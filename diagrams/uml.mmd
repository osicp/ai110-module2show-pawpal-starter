classDiagram
    class Owner {
        +str name
        +int available_time_minutes
        +dict preferences
        +get_owner_details() str
    }

    class Pet {
        +str name
        +str species
        +str breed
        +int age
        +Owner owner
        +get_profile() str
    }

    class Task {
        +str title
        +int duration_minutes
        +str priority
        +str category
        +bool is_completed
        +update_status(completed: bool) void
    }

    class Scheduler {
        +Pet pet
        +Owner owner
        +list tasks
        +list plan
        +str reasoning
        +generate_plan() list
        +get_reasoning() str
    }

    Pet "1" --> "1" Owner : belongs to
    Scheduler "1" --> "1" Pet : schedules for
    Scheduler "1" --> "1" Owner : checks constraints of
    Scheduler "1" *-- "*" Task : organizes


